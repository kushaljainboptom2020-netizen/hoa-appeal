# ─── Canonical site URL ───────────────────────────────────────────────────────
# Required. Used by sitemap.xml, robots.txt, JSON-LD, and Next.js metadataBase.
# Must match your canonical redirect policy (www vs apex).
NEXT_PUBLIC_SITE_URL=https://www.myhoaappeal.com

# ─── Google Analytics 4 (optional) ────────────────────────────────────────────
# GA4 measurement ID from Google Analytics → Admin → Data streams.
# When unset, no analytics script is loaded — safe for dev and staging.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CV35EV8Y9X

# ─── Affiliate links (optional) ───────────────────────────────────────────────
# Set to your affiliate partner IDs to activate CTAs.
# When unset, the corresponding UI element is hidden automatically.
NEXT_PUBLIC_MAILFORM_AFFILIATE_ID=
NEXT_PUBLIC_ROCKETLAWYER_AFFILIATE_ID=

# ─── Google AdSense (optional) ────────────────────────────────────────────────
# Set to your AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX) to render ad slots.
# When unset, ad slot components render nothing.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
